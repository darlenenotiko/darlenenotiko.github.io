---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="项目" description="研究与工程项目">
  <h1 data-reveal>项目</h1>

  <div class="grid">
    {
      projects.map((p) => (
        <a href={`/projects/${p.id}`} class="card project" data-reveal>
          {p.data.cover && (
            <div class="cover">
              <Image src={p.data.cover} alt={p.data.title} widths={[400, 800]} />
            </div>
          )}
          <h2>{p.data.title}</h2>
          <p>{p.data.description}</p>
          {p.data.tags.length > 0 && (
            <div class="tags">
              {p.data.tags.map((t) => (
                <span>{t}</span>
              ))}
            </div>
          )}
        </a>
      ))
    }
  </div>

  {projects.length === 0 && <p class="empty">还没有项目。</p>}
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.3rem;
    margin-top: 2.2rem;
  }
  .project h2 {
    margin: 0;
    font-size: 1.1rem;
  }
  .project p {
    margin: 0.5rem 0 0;
    font-size: 0.91rem;
    color: var(--ink-muted);
  }
  .cover {
    margin: -1.3rem -1.5rem 1rem;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
  }
  .cover :global(img) {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .project:hover .cover :global(img) {
    transform: scale(1.04);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.85rem;
  }
  .tags span {
    padding: 0.08rem 0.5rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-size: 0.75rem;
    color: var(--ink-faint);
  }
  .empty {
    color: var(--ink-faint);
  }
</style>
