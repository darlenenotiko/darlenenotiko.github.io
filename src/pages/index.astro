---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Heatmap from '../components/Heatmap.astro';

// 社区入口：填入知识星球链接后会自动出现在首页；留空则不渲染（不上线死链接）。
const ZHISHIXINGQIU = '';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const papers = (await getCollection('papers'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .filter((p) => p.data.featured)
  .slice(0, 2);

// hero 轨迹：一条平滑的三维感飞行路径。改这里就能换形状
// （注意：下方 CSS 的 offset-path 里有同一份路径，改动需同步）。
const TRAJECTORY =
  'M20,150 C80,150 90,60 150,60 S230,150 290,140 S370,50 430,70 S500,140 560,110';
---

<BaseLayout title="姓名 · 个人主页" description="研究方向、论文、项目与笔记">
  <section class="hero">
    <h1>姓名</h1>
    <p class="tagline">
      某某大学 · 博士研究生。研究无人机的<strong>自主导航与状态估计</strong>，
      关心怎么让机器人在算力和感知都受限的真实世界里可靠地飞起来。
    </p>
    <div class="hero-links">
      <a href="/papers">论文</a>
      <a href="/projects">项目</a>
      <a href="/cv">CV</a>
      <a href="mailto:you@example.com">邮箱</a>
      {
        ZHISHIXINGQIU && (
          <a href={ZHISHIXINGQIU} class="community" target="_blank" rel="noopener">
            <span class="loomtile" aria-hidden="true" />
            知识星球 ↗
          </a>
        )
      }
    </div>

    {/* 层 2 hero：轨迹自绘 + 标记沿路径飞行 */}
    <svg class="traj" viewBox="0 0 580 200" aria-hidden="true" focusable="false">
      <path class="traj-ghost" d={TRAJECTORY} />
      <path class="traj-line" d={TRAJECTORY} />
      <g class="drone">
        <circle class="halo" r="10"></circle>
        <circle r="4"></circle>
      </g>
    </svg>
  </section>

  {
    papers.length > 0 && (
      <section class="block" data-reveal>
        <div class="block-head">
          <h2>精选论文</h2>
          <a href="/papers">全部 →</a>
        </div>
        <ul class="mini">
          {papers.map((p) => (
            <li>
              <span class="key">{p.data.year}</span>
              <div>
                <p class="t">{p.data.title}</p>
                <p class="v">{p.data.venue}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    projects.length > 0 && (
      <section class="block" data-reveal>
        <div class="block-head">
          <h2>精选项目</h2>
          <a href="/projects">全部 →</a>
        </div>
        <div class="cards">
          {projects.map((p) => (
            <a href={`/projects/${p.id}`} class="card">
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  {
    posts.length > 0 && (
      <section class="block" data-reveal>
        <div class="block-head">
          <h2>最近的文章</h2>
          <a href="/blog">全部 →</a>
        </div>
        <ul class="mini">
          {posts.map((post) => (
            <li>
              <span class="key">
                {post.data.date.toLocaleDateString('zh-CN', {
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
              <div>
                <p class="t">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </p>
                {post.data.description && <p class="v">{post.data.description}</p>}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="block" data-reveal>
    <Heatmap />
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 1rem 0 2rem;
  }
  .hero h1 {
    margin: 0;
    font-size: clamp(2.2rem, 6vw, 3.2rem);
  }
  .tagline {
    max-width: 56ch;
    margin: 1rem 0 0;
    font-size: 1.06rem;
    color: var(--ink-muted);
  }
  .tagline strong {
    color: var(--ink);
    font-weight: 600;
  }
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem;
    margin-top: 1.4rem;
    font-size: 0.94rem;
  }
  /* 知识星球：比普通链接稍强调，挂一枚织结 */
  .community {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 0.22rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--weld) 45%, var(--rule));
    border-radius: 999px;
    color: color-mix(in srgb, var(--weld) 72%, var(--ink));
    text-decoration: none;
    transition: border-color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .community .loomtile {
    --tile: var(--weld);
    width: 0.7em;
    height: 0.7em;
  }
  .community:hover {
    border-color: var(--weld);
    background: color-mix(in srgb, var(--weld) 10%, transparent);
  }

  /* ── 轨迹动画 ─────────────────────────────────────────────── */
  .traj {
    display: block;
    width: 100%;
    max-width: 620px;
    height: auto;
    margin-top: 2.2rem;
    overflow: visible;
  }
  .traj-ghost,
  .traj-line {
    fill: none;
    stroke-linecap: round;
  }
  /* 底层虚影常驻，保证动画不生效时画面也完整 */
  .traj-ghost {
    stroke: var(--rule);
    stroke-width: 1.5;
    stroke-dasharray: 3 7;
  }
  .traj-line {
    stroke: var(--accent);
    stroke-width: 2;
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: draw 3.4s var(--ease) 0.3s forwards;
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  .drone {
    /* 与上方 TRAJECTORY 常量保持一致 */
    offset-path: path(
      'M20,150 C80,150 90,60 150,60 S230,150 290,140 S370,50 430,70 S500,140 560,110'
    );
    offset-rotate: auto;
    opacity: 0;
    animation: fly 3.4s var(--ease) 0.3s forwards;
  }
  .drone circle {
    fill: var(--accent);
  }
  .drone .halo {
    fill: color-mix(in srgb, var(--accent) 18%, transparent);
  }
  @keyframes fly {
    0% {
      offset-distance: 0%;
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    100% {
      offset-distance: 100%;
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .traj-line {
      stroke-dashoffset: 0;
      animation: none;
    }
    .drone {
      offset-distance: 100%;
      opacity: 1;
      animation: none;
    }
  }

  /* ── 内容区块 ─────────────────────────────────────────────── */
  .block {
    margin-top: 4rem;
  }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.3rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--rule);
  }
  .block-head h2 {
    margin: 0;
    font-size: 1.15rem;
  }
  .block-head a {
    font-size: 0.85rem;
    color: var(--ink-faint);
    text-decoration: none;
  }
  .block-head a:hover {
    color: var(--accent);
  }

  .mini {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1.1rem;
    max-width: var(--measure);
  }
  .mini li {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.8rem;
    align-items: baseline;
  }
  .mini .key {
    font-size: 0.8rem;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .mini .t {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .mini .t a {
    text-decoration: none;
    color: var(--ink);
  }
  .mini .t a:hover {
    color: var(--accent);
  }
  .mini .v {
    margin: 0.15rem 0 0;
    font-size: 0.86rem;
    color: var(--ink-faint);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.1rem;
  }
  .cards h3 {
    margin: 0;
    font-size: 1.04rem;
  }
  .cards p {
    margin: 0.45rem 0 0;
    font-size: 0.9rem;
    color: var(--ink-muted);
  }

  @media (max-width: 560px) {
    .mini li {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
