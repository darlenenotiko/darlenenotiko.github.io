---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Heatmap from '../components/Heatmap.astro';

// 社区入口：填入知识星球链接后会自动出现在首页；留空则不渲染（不上线死链接）。
const ZHISHIXINGQIU = '';

// 研究方向一句话。同上：填了才出现在首屏，留空就整句不渲染 ——
// 宁可少说一句，也不要在门面上挂一句不准的自我介绍。
// 例：'研究无人机的自主导航与状态估计 —— 怎么让机器人在算力和感知都受限的真实世界里可靠地飞起来。'
const RESEARCH = '';

// 脚手架自带的示例内容（sample-*）不进首页 —— 首页只放真东西。
// 把 src/content/{papers,projects}/sample-* 删掉之后，这个过滤器也可以删。
const isSample = (id: string) => id.startsWith('sample-');

type Chip = { label: string; title: string; href: string };
type Item = {
  date: Date;
  kind: '讲义' | '文章' | '日志' | '项目';
  title: string;
  href: string;
  desc?: string;
  chips?: Chip[];
};

// ── 时间流的四种来源 ──────────────────────────────────────────
const posts: Item[] = (await getCollection('blog', ({ data }) => !data.draft)).map(
  (p) => ({
    date: p.data.date,
    kind: '文章',
    title: p.data.title,
    href: `/blog/${p.id}`,
    desc: p.data.description,
  }),
);

const projects: Item[] = (await getCollection('projects', ({ data }) => !data.draft))
  .filter((p) => !isSample(p.id))
  .map((p) => ({
    date: p.data.date,
    kind: '项目',
    title: p.data.title,
    href: `/projects/${p.id}`,
    desc: p.data.description,
  }));

// 日志没有详情页（在 /logs 的时间线上全文渲染），所以只链到列表页。
const logs: Item[] = (await getCollection('logs')).map((l) => ({
  date: l.data.date,
  kind: '日志',
  title: l.data.title,
  href: '/logs',
}));

// 讲义一门课往往同一天成批上线，逐讲摊进时间流会把别的内容全压下去。
// 所以按课程折叠成一条，日期取该课最新一讲，条目里再铺一排讲次入口。
const notes = await getCollection('courses', ({ data }) => !data.draft);
const byCourse = new Map<string, typeof notes>();
for (const n of notes) {
  const list = byCourse.get(n.data.course) ?? [];
  list.push(n);
  byCourse.set(n.data.course, list);
}
const courses: Item[] = [...byCourse.values()].map((list) => {
  const sorted = list.sort((a, b) => a.data.lecture - b.data.lecture);
  return {
    date: new Date(Math.max(...sorted.map((n) => n.data.date.valueOf()))),
    kind: '讲义' as const,
    title: sorted[0].data.courseTitle,
    href: '/courses',
    desc: `逐讲整理的中文讲义，配可交互的演示。共 ${sorted.length} 讲。`,
    chips: sorted.map((n) => ({
      label: n.data.lectureLabel ?? String(n.data.lecture).padStart(2, '0'),
      title: n.data.title,
      href: `/courses/${n.id}`,
    })),
  };
});

const stream = [...courses, ...posts, ...logs, ...projects]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 8);

// 论文没有日期字段（只有年份），不进时间流，单独一块。
// 目前没有真论文标 featured，所以这块整块不渲染。
const papers = (await getCollection('papers'))
  .filter((p) => p.data.featured && !isSample(p.id))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const thisYear = new Date().getFullYear();
const fmt = (d: Date) =>
  d.toLocaleDateString('zh-CN', {
    year: d.getUTCFullYear() === thisYear ? undefined : 'numeric',
    month: 'numeric',
    day: 'numeric',
    timeZone: 'UTC',
  });

// hero 轨迹：一条平滑的三维感飞行路径。改这里就能换形状
// （注意：下方 CSS 的 offset-path 里有同一份路径，改动需同步）。
const TRAJECTORY =
  'M20,150 C80,150 90,60 150,60 S230,150 290,140 S370,50 430,70 S500,140 560,110';
---

<BaseLayout title="笔记 · 讲义与研究记录" description="逐讲整理的中文课程讲义、研究笔记与日志">
  <section class="hero">
    {/* ↓ 这句标题是占位文案，按你自己的口气改 */}
    <h1>把学过的东西写清楚</h1>
    <p class="tagline">
      这里放<strong>逐讲整理的中文讲义</strong>（配可交互的演示）、研究笔记和日志。
      {RESEARCH}
    </p>
    <div class="hero-links">
      <a href="/courses">讲义</a>
      <a href="/blog">文章</a>
      <a href="/logs">日志</a>
      <a href="/rss.xml">RSS</a>
      {
        ZHISHIXINGQIU && (
          <a href={ZHISHIXINGQIU} class="community" target="_blank" rel="noopener">
            <span class="loomtile" aria-hidden="true" />
            知识星球 ↗
          </a>
        )
      }
    </div>

    {/* 层 2 hero：轨迹自绘 + 标记沿路径飞行 */}
    <svg class="traj" viewBox="0 0 580 200" aria-hidden="true" focusable="false">
      <path class="traj-ghost" d={TRAJECTORY} />
      <path class="traj-line" d={TRAJECTORY} />
      <g class="drone">
        <circle class="halo" r="10"></circle>
        <circle r="4"></circle>
      </g>
    </svg>
  </section>

  {
    stream.length > 0 && (
      <section class="block" data-reveal>
        <div class="block-head">
          <h2>最近</h2>
          <a href="/courses">全部讲义 →</a>
        </div>
        <ol class="feed">
          {stream.map((item) => (
            <li class:list={['feed-item', `kind-${item.kind}`]}>
              <div class="meta">
                <time datetime={item.date.toISOString()}>{fmt(item.date)}</time>
                <span class="kind">{item.kind}</span>
              </div>
              <div class="body">
                <h3>
                  <a href={item.href}>{item.title}</a>
                </h3>
                {item.desc && <p class="desc">{item.desc}</p>}
                {item.chips && (
                  <ul class="chips">
                    {item.chips.map((c) => (
                      <li>
                        <a href={c.href} title={c.title}>
                          {c.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )
  }

  {
    papers.length > 0 && (
      <section class="block" data-reveal>
        <div class="block-head">
          <h2>精选论文</h2>
          <a href="/papers">全部 →</a>
        </div>
        <ul class="mini">
          {papers.map((p) => (
            <li>
              <span class="key">{p.data.year}</span>
              <div>
                <p class="t">{p.data.title}</p>
                <p class="v">{p.data.venue}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="block" data-reveal>
    <Heatmap />
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 1rem 0 2rem;
  }
  .hero h1 {
    margin: 0;
    font-size: clamp(2.1rem, 5.4vw, 2.9rem);
  }
  .tagline {
    max-width: 56ch;
    margin: 1rem 0 0;
    font-size: 1.06rem;
    color: var(--ink-muted);
  }
  .tagline strong {
    color: var(--ink);
    font-weight: 600;
  }
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem;
    margin-top: 1.4rem;
    font-size: 0.94rem;
  }
  /* 知识星球：比普通链接稍强调，挂一枚织结 */
  .community {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 0.22rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--weld) 45%, var(--rule));
    border-radius: 999px;
    color: color-mix(in srgb, var(--weld) 72%, var(--ink));
    text-decoration: none;
    transition: border-color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .community .loomtile {
    --tile: var(--weld);
    width: 0.7em;
    height: 0.7em;
  }
  .community:hover {
    border-color: var(--weld);
    background: color-mix(in srgb, var(--weld) 10%, transparent);
  }

  /* ── 轨迹动画 ─────────────────────────────────────────────── */
  .traj {
    display: block;
    width: 100%;
    max-width: 620px;
    height: auto;
    margin-top: 2.2rem;
    overflow: visible;
  }
  .traj-ghost,
  .traj-line {
    fill: none;
    stroke-linecap: round;
  }
  /* 底层虚影常驻，保证动画不生效时画面也完整 */
  .traj-ghost {
    stroke: var(--rule);
    stroke-width: 1.5;
    stroke-dasharray: 3 7;
  }
  .traj-line {
    stroke: var(--accent);
    stroke-width: 2;
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: draw 3.4s var(--ease) 0.3s forwards;
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  .drone {
    /* 与上方 TRAJECTORY 常量保持一致 */
    offset-path: path(
      'M20,150 C80,150 90,60 150,60 S230,150 290,140 S370,50 430,70 S500,140 560,110'
    );
    offset-rotate: auto;
    opacity: 0;
    animation: fly 3.4s var(--ease) 0.3s forwards;
  }
  .drone circle {
    fill: var(--accent);
  }
  .drone .halo {
    fill: color-mix(in srgb, var(--accent) 18%, transparent);
  }
  @keyframes fly {
    0% {
      offset-distance: 0%;
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    100% {
      offset-distance: 100%;
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .traj-line {
      stroke-dashoffset: 0;
      animation: none;
    }
    .drone {
      offset-distance: 100%;
      opacity: 1;
      animation: none;
    }
  }

  /* ── 内容区块 ─────────────────────────────────────────────── */
  .block {
    margin-top: 4rem;
  }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.3rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--rule);
  }
  .block-head h2 {
    margin: 0;
    font-size: 1.15rem;
  }
  .block-head a {
    font-size: 0.85rem;
    color: var(--ink-faint);
    text-decoration: none;
  }
  .block-head a:hover {
    color: var(--accent);
  }

  /* ── 时间流 ───────────────────────────────────────────────── */
  .feed {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1.6rem;
    max-width: var(--measure);
  }
  .feed-item {
    display: grid;
    grid-template-columns: 5.6rem 1fr;
    gap: 0.9rem;
  }
  .meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    padding-top: 0.15rem;
  }
  .meta time {
    font-size: 0.8rem;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  /* 类型标签：一门内容一种染料，和讲义里的配色同源 */
  .kind {
    --dye: var(--indigo);
    font-size: 0.72rem;
    line-height: 1;
    padding: 0.24em 0.5em;
    border: 1px solid color-mix(in srgb, var(--dye) 35%, transparent);
    border-radius: 4px;
    color: color-mix(in srgb, var(--dye) 80%, var(--ink));
    background: color-mix(in srgb, var(--dye) 7%, transparent);
    white-space: nowrap;
  }
  .kind-文章 .kind {
    --dye: var(--madder);
  }
  .kind-日志 .kind {
    --dye: var(--weld);
  }
  .kind-项目 .kind {
    --dye: var(--indigo-soft);
  }

  .body h3 {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.45;
    font-weight: 600;
  }
  .body h3 a {
    color: var(--ink);
    text-decoration: none;
  }
  .body h3 a:hover {
    color: var(--accent);
  }
  .desc {
    margin: 0.25rem 0 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--ink-faint);
  }

  /* 讲次入口：一排小方牌，密而不挤，像一匹布上的经线刻度 */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0.7rem 0 0;
    padding: 0;
    list-style: none;
  }
  .chips a {
    display: block;
    min-width: 2rem;
    padding: 0.28rem 0.42rem;
    border: 1px solid var(--rule);
    border-radius: 5px;
    background: var(--bg-raised);
    font-size: 0.78rem;
    line-height: 1;
    text-align: center;
    font-variant-numeric: tabular-nums;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.18s var(--ease), border-color 0.18s var(--ease),
      background-color 0.18s var(--ease);
  }
  .chips a:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--rule));
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-raised));
  }

  /* ── 论文小列表 ───────────────────────────────────────────── */
  .mini {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1.1rem;
    max-width: var(--measure);
  }
  .mini li {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.8rem;
    align-items: baseline;
  }
  .mini .key {
    font-size: 0.8rem;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .mini .t {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .mini .v {
    margin: 0.15rem 0 0;
    font-size: 0.86rem;
    color: var(--ink-faint);
  }

  @media (max-width: 560px) {
    .feed-item {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
    .meta {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
      padding-top: 0;
    }
    .mini li {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
