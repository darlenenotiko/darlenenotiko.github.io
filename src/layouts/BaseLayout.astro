---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/temml-libertinus.css'; // Temml MathML 样式 + Libertinus Math 字体（self-host，与正文同源）

interface Props {
  title: string;
  description?: string;
}

const { title, description = '个人主页' } = Astro.props;

const nav = [
  { href: '/', label: '首页' },
  { href: '/papers', label: '论文' },
  { href: '/blog', label: '博客' },
  { href: '/projects', label: '项目' },
  { href: '/logs', label: '日志' },
  { href: '/cv', label: 'CV' },
];

const path = Astro.url.pathname;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="alternate" type="application/rss+xml" title={title} href="/rss.xml" />

    {/* 主题必须在首次绘制前确定，否则会闪一下白屏 */}
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const theme =
          saved ??
          (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <ClientRouter />
  </head>

  <body>
    <header class="site-header">
      <div class="page header-inner">
        <a href="/" class="brand">姓名</a>
        <nav>
          {
            nav.slice(1).map((item) => (
              <a
                href={item.href}
                class:list={['nav-link', { active: path.startsWith(item.href) }]}
              >
                {item.label}
              </a>
            ))
          }
          <button id="theme-toggle" aria-label="切换深色模式" title="切换深色模式">
            <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true">
              <path
                class="sun"
                fill="currentColor"
                d="M12 7a5 5 0 100 10 5 5 0 000-10zm0-5v3m0 14v3M2 12h3m14 0h3M4.2 4.2l2.1 2.1m11.4 11.4l2.1 2.1M19.8 4.2l-2.1 2.1M6.3 17.7l-2.1 2.1"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
              ></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="page">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="page">
        <span>© {new Date().getFullYear()} 姓名</span>
        <span class="dot">·</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>

    <script>
      // 主题切换 + 滚动淡入。
      // ClientRouter 下页面切换不会重新执行 <script>，所以监听 astro:page-load。
      function setupReveal() {
        const els = document.querySelectorAll('[data-reveal]:not(.is-visible)');
        if (!els.length) return;

        // 系统开启了「减少动效」时直接全部显示，不做观察
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
        );
        els.forEach((el) => io.observe(el));
      }

      function setupTheme() {
        const btn = document.getElementById('theme-toggle');
        if (!btn || btn.dataset.bound) return;
        btn.dataset.bound = 'true';
        btn.addEventListener('click', () => {
          const next =
            document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        });
      }

      // ClientRouter 的 swap 会用新文档的 <html> 属性覆盖当前的，
      // 并删掉服务端产物里不存在的属性 —— data-theme 是运行时加的，会被抹掉。
      // astro:after-swap 在绘制前触发，在这里重新应用就不会闪。
      function applyTheme() {
        const saved = localStorage.getItem('theme');
        document.documentElement.dataset.theme =
          saved ??
          (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      }

      // 代码块：加语言标签 + 复制按钮（渐进增强，纯前端）
      function enhanceCodeBlocks() {
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.dataset.enhanced) return;
          pre.dataset.enhanced = 'true';
          const code = pre.querySelector('code');
          if (!code) return;

          const lang = pre.getAttribute('data-language');
          const bar = document.createElement('div');
          bar.className = 'code-bar';
          if (lang && lang !== 'plaintext' && lang !== 'text') {
            const tag = document.createElement('span');
            tag.className = 'code-lang';
            tag.textContent = lang;
            bar.appendChild(tag);
          }
          const btn = document.createElement('button');
          btn.className = 'code-copy';
          btn.type = 'button';
          btn.textContent = '复制';
          btn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(code.textContent ?? '');
              btn.textContent = '已复制';
              btn.classList.add('is-done');
              setTimeout(() => {
                btn.textContent = '复制';
                btn.classList.remove('is-done');
              }, 1500);
            } catch {
              btn.textContent = '复制失败';
            }
          });
          bar.appendChild(btn);
          pre.appendChild(bar);
        });
      }

      setupReveal();
      setupTheme();
      enhanceCodeBlocks();
      document.addEventListener('astro:after-swap', applyTheme);
      document.addEventListener('astro:page-load', () => {
        setupReveal();
        setupTheme();
        enhanceCodeBlocks();
      });
    </script>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        backdrop-filter: saturate(1.6) blur(10px);
        border-bottom: 1px solid var(--rule);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        height: 60px;
      }
      .brand {
        font-family: var(--font-serif);
        font-size: 1.12rem;
        font-weight: 600;
        color: var(--ink);
        text-decoration: none;
      }
      nav {
        display: flex;
        align-items: center;
        gap: clamp(0.7rem, 2.2vw, 1.5rem);
      }
      .nav-link {
        position: relative;
        font-size: 0.92rem;
        color: var(--ink-muted);
        text-decoration: none;
        padding: 0.2rem 0;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: -2px;
        height: 1.5px;
        width: 100%;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.3s var(--ease);
      }
      .nav-link:hover,
      .nav-link.active {
        color: var(--ink);
      }
      .nav-link:hover::after,
      .nav-link.active::after {
        transform: scaleX(1);
        transform-origin: left;
      }
      #theme-toggle {
        display: grid;
        place-items: center;
        width: 32px;
        height: 32px;
        border: 1px solid var(--rule);
        border-radius: 8px;
        background: transparent;
        color: var(--ink-muted);
        cursor: pointer;
        transition: color 0.2s var(--ease), border-color 0.2s var(--ease),
          transform 0.3s var(--ease);
      }
      #theme-toggle:hover {
        color: var(--accent);
        border-color: var(--accent);
        transform: rotate(35deg);
      }

      main.page {
        min-height: 68vh;
        padding-top: 3rem;
        padding-bottom: 5rem;
      }

      .site-footer {
        border-top: 1px solid var(--rule);
        padding: 1.8rem 0;
        font-size: 0.86rem;
        color: var(--ink-faint);
      }
      .site-footer a {
        color: var(--ink-faint);
      }
      .site-footer a:hover {
        color: var(--accent);
      }
      .dot {
        margin: 0 0.5rem;
      }
    </style>
  </body>
</html>
