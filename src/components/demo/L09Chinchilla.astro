---
// C = 6ND 权衡器：固定算力预算 C，拖动模型大小 N，数据量 D = C/(6N) 被动跟着变。
// 损失用 Chinchilla 的参数化形式 L(N,D) = E + A/N^α + B/D^β 算，
// 可以在 Hoffmann+ 2022 原论文的方法三拟合、和 Besiroglu+ 2024 的重拟合之间切换。
// 图上同时标出：当前位置、这个预算下的真正最优点、以及 D = 20N 这条经验法则给出的点。
---

<div class="demo" data-demo="l09-chinchilla">
  <div class="ctrl">
    <span class="tag">算力预算 C</span>
    <select data-budget>
      <option value="1e21">1e21 FLOPs</option>
      <option value="1e22">1e22 FLOPs</option>
      <option value="1e23">1e23 FLOPs</option>
      <option value="5.76e23" selected>5.76e23 FLOPs（Gopher / Chinchilla 用掉的量）</option>
      <option value="1e25">1e25 FLOPs</option>
    </select>
  </div>
  <div class="ctrl">
    <label>模型大小 N <input type="range" data-n min="0" max="1000" step="1" value="500" /></label>
    <button data-goopt>跳到最优点</button>
    <button data-go20>跳到 D = 20N</button>
  </div>
  <div class="ctrl">
    <span class="tag">损失曲面的系数</span>
    <button data-coef="hoffmann" class="on">Hoffmann 2022（方法三）</button>
    <button data-coef="besiroglu">Besiroglu 2024（重拟合）</button>
  </div>

  <div class="two">
    <div class="plot" data-plot></div>
    <table class="out" data-out><tbody></tbody></table>
  </div>

  <p class="formula" data-formula></p>
  <p class="verdict" data-verdict></p>
</div>

<style>
  .demo {
    margin: 2rem 0;
    padding: 0.9rem 1.2rem 1.2rem;
    background: var(--bg-sunken);
    border: 1px solid var(--rule);
    border-radius: 10px;
  }
  .ctrl {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .tag {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }
  .ctrl label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--ink-muted);
  }
  .ctrl input[type='range'] {
    width: 240px;
    accent-color: var(--indigo);
  }
  .ctrl select {
    padding: 0.26rem 0.4rem;
    font: inherit;
    font-size: 0.8rem;
    color: var(--ink);
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-radius: 5px;
  }
  .ctrl button {
    padding: 0.26rem 0.65rem;
    font: inherit;
    font-size: 0.78rem;
    color: var(--ink-muted);
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-radius: 5px;
    cursor: pointer;
    transition: all 0.2s var(--ease);
  }
  .ctrl button:hover {
    color: var(--indigo);
    border-color: var(--indigo);
  }
  .ctrl button.on {
    color: var(--bg);
    background: var(--indigo);
    border-color: var(--indigo);
  }
  .ctrl button.on:hover {
    color: var(--bg);
  }

  .two {
    display: grid;
    gap: 1rem;
    margin-top: 0.8rem;
    align-items: start;
  }
  @media (min-width: 720px) {
    .two {
      grid-template-columns: 1.2fr 1fr;
    }
  }
  .plot {
    overflow-x: auto;
  }
  .plot :global(svg) {
    display: block;
    width: 100%;
    min-width: 320px;
    height: auto;
  }
  .plot :global(.axis) {
    stroke: var(--rule);
    stroke-width: 1;
  }
  .plot :global(.grid) {
    stroke: var(--rule);
    stroke-width: 0.6;
    stroke-dasharray: 2 3;
  }
  .plot :global(.curve) {
    fill: none;
    stroke: var(--indigo);
    stroke-width: 2;
  }
  .plot :global(.cur) {
    fill: var(--madder);
  }
  .plot :global(.curline) {
    stroke: var(--madder);
    stroke-width: 1;
    stroke-dasharray: 2 2;
  }
  .plot :global(.opt) {
    fill: none;
    stroke: var(--weld);
    stroke-width: 1.6;
  }
  .plot :global(.optline) {
    stroke: var(--weld);
    stroke-width: 1;
    stroke-dasharray: 3 3;
  }
  .plot :global(.rule20) {
    stroke: var(--ink-faint);
    stroke-width: 1;
    stroke-dasharray: 1 3;
  }
  .plot :global(text) {
    fill: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: 9px;
  }
  .plot :global(text.title) {
    fill: var(--indigo);
    font-size: 10.5px;
    font-weight: 700;
  }
  .plot :global(text.gold) {
    fill: var(--weld);
    font-size: 9.5px;
    font-weight: 700;
  }
  .plot :global(text.red) {
    fill: var(--madder);
    font-size: 9.5px;
    font-weight: 700;
  }

  .out {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  .out :global(td) {
    padding: 0.3rem 0.35rem;
    border-bottom: 1px solid var(--rule);
    color: var(--ink-muted);
  }
  .out :global(td.v) {
    text-align: right;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }
  .out :global(tr.hi td) {
    color: var(--madder);
    font-weight: 700;
  }
  .out :global(tr.gold td) {
    color: var(--weld);
    font-weight: 700;
  }

  .formula {
    margin: 0.9rem 0 0.2rem;
    padding: 0.5rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.85;
    color: var(--ink-muted);
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow-x: auto;
    white-space: pre-wrap;
  }

  .verdict {
    margin: 0.9rem 0 0;
    font-size: 0.85rem;
    line-height: 1.75;
    color: var(--ink-muted);
  }
  .verdict :global(strong) {
    color: var(--madder);
  }
</style>

<script>
  function setupL09Chinchilla() {
    document.querySelectorAll<HTMLElement>('[data-demo="l09-chinchilla"]').forEach((root) => {
      if (root.dataset.ready) return;
      root.dataset.ready = '1';

      const $ = <T extends HTMLElement>(s: string) => root.querySelector<T>(s)!;

      const COEF = {
        hoffmann: { E: 1.69, A: 406.4, B: 410.7, al: 0.34, be: 0.28, name: 'Hoffmann 2022 方法三' },
        besiroglu: { E: 1.82, A: 482.01, B: 2085.43, al: 0.3478, be: 0.3658, name: 'Besiroglu 2024 重拟合' },
      };
      let coefKey: keyof typeof COEF = 'hoffmann';

      const nSlider = $<HTMLInputElement>('[data-n]');
      const budgetSel = $<HTMLSelectElement>('[data-budget]');
      // 滑块和 <select> 都有量化 / 默认值的坑，所以当前状态单独用变量存，
      // 「跳到最优点」「跳到 D = 20N」设的是精确值，不受滑块 1/1000 的分辨率影响
      let curC = 5.76e23;
      let curN = 0;

      const fmtParam = (x: number) => {
        if (!isFinite(x) || x <= 0) return '—';
        if (x >= 1e12) return (x / 1e12).toFixed(2) + 'T';
        if (x >= 1e9) return (x / 1e9).toFixed(2) + 'B';
        if (x >= 1e6) return (x / 1e6).toFixed(1) + 'M';
        return x.toExponential(2);
      };
      const svgEl = (tag: string, attrs: Record<string, string | number>, text?: string) => {
        const e = document.createElementNS('http://www.w3.org/2000/svg', tag);
        for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, String(v));
        if (text !== undefined) e.textContent = text;
        return e;
      };

      const budget = () => curC;
      // D = 20N 那个点：C = 6·N·20N = 120N²
      const n20 = (C: number) => Math.sqrt(C / 120);
      // 解析最优点：N* = [αA / (βB·6^β)]^(1/(α+β)) · C^(β/(α+β))
      const nOpt = (C: number) => {
        const { A, B, al, be } = COEF[coefKey];
        const k = Math.pow((al * A) / (be * B * Math.pow(6, be)), 1 / (al + be));
        return k * Math.pow(C, be / (al + be));
      };
      const lossAt = (N: number, C: number) => {
        const { E, A, B, al, be } = COEF[coefKey];
        const D = C / (6 * N);
        return E + A * Math.pow(N, -al) + B * Math.pow(D, -be);
      };

      // 滑块位置 0…1000 映射到 log10 N，窗口以 D=20N 那个点为中心
      const range = (C: number) => {
        const c = Math.log10(n20(C));
        return { lo: c - 1.4, hi: c + 1.4 };
      };
      const sliderToN = (C: number) => {
        const { lo, hi } = range(C);
        return Math.pow(10, lo + ((hi - lo) * parseFloat(nSlider.value)) / 1000);
      };
      const nToSlider = (N: number, C: number) => {
        const { lo, hi } = range(C);
        return Math.round(((Math.log10(N) - lo) / (hi - lo)) * 1000);
      };

      const W = 420,
        H = 270,
        ML = 46,
        MR = 14,
        MT = 24,
        MB = 34;

      function draw() {
        const C = budget();
        const { lo, hi } = range(C);
        const N = curN;
        const D = C / (6 * N);
        const L = lossAt(N, C);

        const NO = nOpt(C);
        const DO = C / (6 * NO);
        const LO = lossAt(NO, C);

        const N20 = n20(C);
        const L20 = lossAt(N20, C);

        // 曲线采样
        const xs: number[] = [],
          ys: number[] = [];
        for (let i = 0; i <= 200; i++) {
          const lx = lo + ((hi - lo) * i) / 200;
          xs.push(lx);
          ys.push(lossAt(Math.pow(10, lx), C));
        }
        const Y0 = Math.min(...ys) - 0.03;
        const Y1 = Math.min(Math.max(...ys), LO + 1.2) + 0.03;

        const px = (lx: number) => ML + ((lx - lo) / (hi - lo)) * (W - ML - MR);
        const py = (y: number) => H - MB - ((y - Y0) / (Y1 - Y0)) * (H - MT - MB);
        const clamp = (y: number) => Math.min(Math.max(y, Y0), Y1);

        const svg = svgEl('svg', { viewBox: `0 0 ${W} ${H}` });
        for (let e = Math.ceil(lo); e <= Math.floor(hi); e++) {
          const x = px(e);
          svg.append(svgEl('line', { class: 'grid', x1: x, y1: MT, x2: x, y2: H - MB }));
          svg.append(svgEl('text', { x, y: H - MB + 12, 'text-anchor': 'middle' }, `10^${e}`));
        }
        for (let i = 0; i <= 4; i++) {
          const v = Y0 + ((Y1 - Y0) * i) / 4;
          const y = py(v);
          svg.append(svgEl('line', { class: 'grid', x1: ML, y1: y, x2: W - MR, y2: y }));
          svg.append(svgEl('text', { x: ML - 4, y: y + 3, 'text-anchor': 'end' }, v.toFixed(2)));
        }
        svg.append(svgEl('line', { class: 'axis', x1: ML, y1: H - MB, x2: W - MR, y2: H - MB }));
        svg.append(svgEl('line', { class: 'axis', x1: ML, y1: MT, x2: ML, y2: H - MB }));
        svg.append(
          svgEl('text', { class: 'title', x: ML, y: 14 }, `固定 C = ${C.toExponential(2)} FLOPs，只有 N 一个自由度`),
        );
        svg.append(
          svgEl('text', { x: (ML + W - MR) / 2, y: H - 3, 'text-anchor': 'middle' }, '模型参数量 N（对数）'),
        );
        svg.append(
          svgEl(
            'text',
            { x: 9, y: (MT + H - MB) / 2, 'text-anchor': 'middle', transform: `rotate(-90 9 ${(MT + H - MB) / 2})` },
            '预测损失 L(N, C/6N)',
          ),
        );

        svg.append(
          svgEl('polyline', {
            class: 'curve',
            points: xs.map((lx, i) => `${px(lx)},${py(clamp(ys[i]))}`).join(' '),
          }),
        );

        // D = 20N 参考线
        svg.append(svgEl('line', { class: 'rule20', x1: px(Math.log10(N20)), y1: MT, x2: px(Math.log10(N20)), y2: H - MB }));
        svg.append(
          svgEl('text', { x: px(Math.log10(N20)) + 3, y: MT + 9 }, `D = 20N（${fmtParam(N20)}）`),
        );

        // 最优点
        svg.append(svgEl('line', { class: 'optline', x1: px(Math.log10(NO)), y1: py(clamp(LO)), x2: px(Math.log10(NO)), y2: H - MB }));
        svg.append(svgEl('circle', { class: 'opt', cx: px(Math.log10(NO)), cy: py(clamp(LO)), r: 5 }));
        svg.append(
          svgEl('text', { class: 'gold', x: px(Math.log10(NO)), y: py(clamp(LO)) - 9, 'text-anchor': 'middle' }, '最优'),
        );

        // 当前点
        svg.append(svgEl('line', { class: 'curline', x1: px(Math.log10(N)), y1: py(clamp(L)), x2: px(Math.log10(N)), y2: H - MB }));
        svg.append(svgEl('circle', { class: 'cur', cx: px(Math.log10(N)), cy: py(clamp(L)), r: 4 }));

        $('[data-plot]').replaceChildren(svg);

        // ── 右边的读数表 ──
        const tb = $('[data-out] tbody');
        tb.replaceChildren();
        const row = (k: string, v: string, cls = '') => {
          const tr = document.createElement('tr');
          if (cls) tr.className = cls;
          const a = document.createElement('td');
          a.textContent = k;
          const b = document.createElement('td');
          b.className = 'v';
          b.textContent = v;
          tr.append(a, b);
          tb.append(tr);
        };
        row('算力预算 C', C.toExponential(2) + ' FLOPs');
        row('你选的模型大小 N', fmtParam(N), 'hi');
        row('被动决定的数据量 D', fmtParam(D) + ' token', 'hi');
        row('token / 参数 = D/N', (D / N).toFixed(1), 'hi');
        row('这一组的损失', L.toFixed(4), 'hi');
        row('—', '—');
        row('最优的 N*', fmtParam(NO), 'gold');
        row('对应的 D*', fmtParam(DO) + ' token', 'gold');
        row('最优处的 D*/N*', (DO / NO).toFixed(1), 'gold');
        row('最优损失', LO.toFixed(4), 'gold');
        row('你比最优差', (L - LO).toFixed(4));
        row('D = 20N 处的损失', L20.toFixed(4) + `（差 ${(L20 - LO).toFixed(4)}）`);

        const cf = COEF[coefKey];
        $('[data-formula]').textContent =
          `预算约束　C = 6ND　→　给定 C 和 N，数据量没得选：D = C / (6N) = ${D.toExponential(3)}\n` +
          `损失曲面　L(N, D) = E + A/N^α + B/D^β\n` +
          `　　　　　${cf.name}：E = ${cf.E}，A = ${cf.A}，B = ${cf.B}，α = ${cf.al}，β = ${cf.be}\n` +
          `代入　　　L = ${cf.E} + ${cf.A}/N^${cf.al} + ${cf.B}/D^${cf.be} = ${cf.E} + ${(cf.A * Math.pow(N, -cf.al)).toFixed(4)} + ${(cf.B * Math.pow(D, -cf.be)).toFixed(4)} = ${L.toFixed(4)}\n` +
          `令 dL/dN = 0 解得　N* ∝ C^(β/(α+β)) = C^${(cf.be / (cf.al + cf.be)).toFixed(4)}，　D* ∝ C^${(cf.al / (cf.al + cf.be)).toFixed(4)}`;

        const v = $('[data-verdict]');
        v.replaceChildren();
        const s = document.createElement('strong');
        s.textContent = `${(DO / NO).toFixed(1)} token / 参数`;
        v.append(
          document.createTextNode(
            `把 N 往左拖：模型变小，数据变多，损失被「模型太小装不下」拖住；往右拖：模型变大，数据变少，损失被「数据不够喂不饱」拖住。中间那个谷底就是这个预算下的计算最优点，此时 `,
          ),
          s,
          document.createTextNode(
            `。切换到另一组系数看看这个比值怎么变 —— Hoffmann 原论文方法三的指数 α、β 不相等，导致 D*/N* 会随预算一路往上爬；Besiroglu 2024 重新拟合之后，它基本稳定在 20 附近，也就是大家熟悉的那条经验法则。`,
          ),
        );
      }

      const jump = (N: number) => {
        curN = N;
        nSlider.value = String(Math.min(1000, Math.max(0, nToSlider(N, curC))));
        draw();
      };

      budgetSel.addEventListener('change', () => {
        curC = parseFloat(budgetSel.value);
        jump(n20(curC)); // 换预算后落在 D = 20N 这个好认的点上
      });
      nSlider.addEventListener('input', () => {
        curN = sliderToN(curC);
        draw();
      });
      $('[data-goopt]').addEventListener('click', () => jump(nOpt(curC)));
      $('[data-go20]').addEventListener('click', () => jump(n20(curC)));
      root.querySelectorAll<HTMLButtonElement>('[data-coef]').forEach((btn) => {
        btn.addEventListener('click', () => {
          coefKey = btn.dataset.coef as keyof typeof COEF;
          root.querySelectorAll('[data-coef]').forEach((b) => b.classList.toggle('on', b === btn));
          draw();
        });
      });

      budgetSel.value = '5.76e23';
      jump(n20(curC));
    });
  }

  setupL09Chinchilla();
  document.addEventListener('astro:page-load', setupL09Chinchilla);
</script>
