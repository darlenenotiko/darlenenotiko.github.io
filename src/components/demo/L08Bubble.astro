---
// CS336 第 8 讲：流水线并行的气泡图。
// 时间 × 设备的格子。F_{i,j} = 第 i 个流水线阶段处理第 j 个 micro-batch 的前向，
// B_{i,j} 是对应的反向。调度按课件第 34 页那张 GPipe 图：
//   F_{i,j} 在时刻 i + j
//   B_{i,j} 在时刻 (p+m-1) + (m-1-j) + (p-1-i)
// 于是每卡有用格子 2m，总格子 2(p+m-1)，气泡 / 有用 = (p-1)/m —— 就是课件上那个公式。
---

<div class="demo" data-demo="l08-bubble">
  <div class="row">
    <label class="sld">
      流水线阶段数 p = <span data-p-val>4</span>
      <input type="range" data-p min="2" max="8" step="1" value="4" />
    </label>
    <label class="sld">
      micro-batch 数 m = <span data-m-val>4</span>
      <input type="range" data-m min="1" max="16" step="1" value="4" />
    </label>
  </div>

  <div class="two">
    <div>
      <canvas data-canvas width="760" height="260"></canvas>
      <p class="axis">
        横轴 = 时间（每格是「一个 micro-batch 在一个阶段上跑一次」的时长），纵轴 = 设备。
        靛蓝 = 前向 F，茜红 = 反向 B，最右边黄色 = 参数更新。空白格 = 气泡（这张卡在干等）。
      </p>
    </div>
    <div>
      <table>
        <tbody data-stats></tbody>
      </table>
      <p class="hint" data-hint></p>
    </div>
  </div>
</div>

<style>
  .demo {
    margin: 2rem 0;
    padding: 1rem 1.2rem 1.2rem;
    background: var(--bg-sunken);
    border: 1px solid var(--rule);
    border-radius: 10px;
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 1.3rem;
    margin-bottom: 0.8rem;
  }
  .sld {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.83rem;
    color: var(--ink-muted);
    font-variant-numeric: tabular-nums;
  }
  .sld input[type='range'] {
    width: 150px;
    accent-color: var(--indigo);
  }
  .two {
    display: grid;
    gap: 1.2rem;
    align-items: start;
  }
  @media (min-width: 860px) {
    .two {
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    }
  }
  canvas {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-radius: 6px;
  }
  .axis {
    margin: 0.45rem 0 0;
    font-size: 0.76rem;
    color: var(--ink-faint);
    line-height: 1.7;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.81rem;
    font-variant-numeric: tabular-nums;
  }
  table :global(td) {
    padding: 0.28rem 0.4rem;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--rule);
  }
  table :global(td.k) {
    color: var(--ink-faint);
  }
  table :global(td.v) {
    text-align: right;
    font-family: var(--font-mono);
    color: var(--ink);
  }
  table :global(tr.hi td.v) {
    color: var(--madder);
    font-weight: 700;
  }
  .hint {
    margin: 0.9rem 0 0;
    font-size: 0.83rem;
    line-height: 1.8;
    color: var(--ink-muted);
  }
</style>

<script>
  function setupL08Bubble() {
    document.querySelectorAll<HTMLElement>('[data-demo="l08-bubble"]').forEach((root) => {
      if (root.dataset.ready) return;
      root.dataset.ready = '1';

      const $ = <T extends HTMLElement>(s: string) => root.querySelector<T>(s)!;
      const cv = $<HTMLCanvasElement>('[data-canvas]');
      const ctx = cv.getContext('2d')!;
      const css = (n: string) =>
        getComputedStyle(document.documentElement).getPropertyValue(n).trim();

      function draw() {
        const p = parseInt($<HTMLInputElement>('[data-p]').value, 10);
        const m = parseInt($<HTMLInputElement>('[data-m]').value, 10);
        $('[data-p-val]').textContent = String(p);
        $('[data-m-val]').textContent = String(m);

        // ── 排出时间表 ──
        const span = 2 * (p + m - 1); // 从第一个前向到最后一个反向结束，占多少个时间格
        // grid[stage][t] = 'F' | 'B' | ''，另外最右边单独留一列画 Update
        const grid: string[][] = [];
        const labels: string[][] = [];
        for (let i = 0; i < p; i++) {
          grid.push(new Array(span).fill(''));
          labels.push(new Array(span).fill(''));
        }
        for (let i = 0; i < p; i++) {
          for (let j = 0; j < m; j++) {
            const tf = i + j;
            grid[i][tf] = 'F';
            labels[i][tf] = `F${i},${j}`;
            const tb = p + m - 1 + (m - 1 - j) + (p - 1 - i);
            grid[i][tb] = 'B';
            labels[i][tb] = `B${i},${j}`;
          }
        }

        // ── 画 ──
        const cols = span + 1; // 最后一列是 Update
        const padL = 46;
        const padT = 14;
        const cw = Math.max(6, Math.min(46, (cv.width - padL - 8) / cols));
        const ch = Math.min(34, (cv.height - padT - 22) / p);
        const indigo = css('--indigo');
        const madder = css('--madder');
        const weld = css('--weld');
        const rule = css('--rule');
        const faint = css('--ink-faint');

        ctx.clearRect(0, 0, cv.width, cv.height);
        ctx.font = '11px ui-monospace, monospace';
        ctx.textBaseline = 'middle';

        for (let i = 0; i < p; i++) {
          // 设备编号从下往上画，和课件那张图一致（阶段 0 在最下面）
          const rowY = padT + (p - 1 - i) * ch;
          ctx.fillStyle = faint;
          ctx.textAlign = 'right';
          ctx.fillText(`阶段 ${i}`, padL - 6, rowY + ch / 2);
          ctx.textAlign = 'center';

          for (let t = 0; t < span; t++) {
            const x = padL + t * cw;
            const kind = grid[i][t];
            if (kind) {
              ctx.fillStyle = kind === 'F' ? indigo : madder;
              ctx.globalAlpha = 0.82;
              ctx.fillRect(x, rowY, Math.max(1, cw - 1), Math.max(1, ch - 1));
              ctx.globalAlpha = 1;
              if (cw >= 30 && ch >= 18) {
                ctx.fillStyle = '#fff';
                ctx.fillText(labels[i][t], x + cw / 2, rowY + ch / 2);
              }
            } else {
              ctx.strokeStyle = rule;
              ctx.lineWidth = 1;
              ctx.strokeRect(x + 0.5, rowY + 0.5, Math.max(1, cw - 2), Math.max(1, ch - 2));
            }
          }
          // Update 列
          const ux = padL + span * cw;
          ctx.fillStyle = weld;
          ctx.globalAlpha = 0.75;
          ctx.fillRect(ux, rowY, Math.max(1, cw - 1), Math.max(1, ch - 1));
          ctx.globalAlpha = 1;
        }

        ctx.fillStyle = faint;
        ctx.textAlign = 'left';
        ctx.fillText('时间 →', padL, padT + p * ch + 12);

        // ── 统计 ──
        const usefulPerDevice = 2 * m;
        const bubblePerDevice = span - usefulPerDevice; // = 2(p-1)
        const util = usefulPerDevice / span; // = m / (m + p - 1)
        const bubbleRatio = (p - 1) / m;

        const rows: [string, string, boolean][] = [
          ['每卡有用的格子（m 次前向 + m 次反向）', `${usefulPerDevice}`, false],
          ['每卡空转的格子', `${bubblePerDevice}`, false],
          ['一步总共占用的时间格', `${span}`, false],
          ['气泡 ÷ 有用计算 = (p−1)/m', bubbleRatio.toFixed(3), true],
          ['利用率 = m/(m+p−1)', `${(util * 100).toFixed(1)} %`, true],
        ];
        const tb = $('[data-stats]');
        tb.replaceChildren();
        for (const [k, v, hi] of rows) {
          const tr = document.createElement('tr');
          if (hi) tr.className = 'hi';
          const a = document.createElement('td');
          a.className = 'k';
          a.textContent = k;
          const b = document.createElement('td');
          b.className = 'v';
          b.textContent = v;
          tr.append(a, b);
          tb.append(tr);
        }

        let hint: string;
        if (m === 1) {
          hint =
            `m = 1 就是「朴素逐层并行」：整批数据一口气往上推，一个时刻只有一张卡在算，` +
            `利用率恰好是 1/p = ${(100 / p).toFixed(1)}%。这就是课件上那句「n 张卡，每张卡只有 1/n 的时间在干活」。`;
        } else if (bubbleRatio > 0.5) {
          hint =
            `micro-batch 还是太少：气泡是有用计算的 ${bubbleRatio.toFixed(2)} 倍，` +
            `${(100 - util * 100).toFixed(0)}% 的卡时间在干等。继续往右拖 m。`;
        } else if (bubbleRatio > 0.15) {
          hint =
            `已经好多了。注意气泡格子数只跟 p 有关（永远是 2(p−1) = ${bubblePerDevice} 格），` +
            `而有用格子随 m 线性增长 —— 所以 (p−1)/m 是靠「分母变大」压下去的，不是靠气泡变小。`;
        } else {
          hint =
            `气泡已经被摊薄到 ${(bubbleRatio * 100).toFixed(1)}%。代价是：m 个 micro-batch 要凑成一个大批次，` +
            `所以流水线并行是在花掉批大小这个资源。批大小不够时只能靠梯度累积去凑。`;
        }
        $('[data-hint]').textContent = hint;
      }

      root.querySelectorAll('input').forEach((el) => el.addEventListener('input', draw));
      new MutationObserver(draw).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      });
      draw();
    });
  }

  setupL08Bubble();
  document.addEventListener('astro:page-load', setupL08Bubble);
</script>
