  }

  .comm {
    display: grid;
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .comm {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .comm :global(.cc) {
    padding: 0.55rem 0.65rem;
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-radius: 6px;
  }
  .comm :global(.cc.hot) {
    border-color: var(--madder);
  }
  .comm :global(.ct) {
    font-size: 0.7rem;
