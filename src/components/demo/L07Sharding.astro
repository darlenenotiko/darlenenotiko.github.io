  }
  .viz :global(.r3) {
    background: color-mix(in srgb, var(--indigo-soft) 40%, transparent);
  }
  .viz :global(.r4) {
    background: color-mix(in srgb, var(--indigo) 16%, transparent);
  }
  .viz :global(.r5) {
    background: color-mix(in srgb, var(--madder) 14%, transparent);
  }
  .viz :global(.r6) {
    background: color-mix(in srgb, var(--weld) 20%, transparent);
  }
  .viz :global(.r7) {
