  .bars :global(.brow.on .bfill) {
    background: color-mix(in srgb, var(--madder) 30%, transparent);
  }
  .bars :global(.bnum) {
    position: absolute;
    left: 0.45rem;
    top: 0;
    line-height: 1.35rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
