    color: var(--ink-faint);
  }
  .comm :global(.cv) {
    margin-top: 0.18rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--ink);
  }
  .comm :global(.cc.hot .cv) {
    color: var(--madder);
  }

  .bars {
    display: grid;
    gap: 0.45rem;
  }
  .bars :global(.brow) {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
  .bars :global(.btrack) {
