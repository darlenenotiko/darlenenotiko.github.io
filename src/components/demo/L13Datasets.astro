          notes: [
            '要回答的问题：只用宽松许可的数据，能训出多好的模型？',
            '来源包括 Stack V2 代码、政府与法律文书（USPTO、CAP、USGPO、UK Hansard、Regulations.gov）、维基类站点、部分网页与新闻、学术论文、在线论坛、公有领域书籍、教育资源。',
            '坑一：许可证洗白 —— 有人把受版权保护的东西随手打上 CC-BY，很难查。',
            '坑二：集合的许可证（比如 Dolma 是 ODC-By）不会自动传递到集合里的每一份作品。',
            '坑三：他们干脆不用任何合成数据 —— 因为生成它的语言模型本身多半训过没授权的数据，那就成了另一种洗白。',
            '结论：能做到不错，但要真正竞争还是缺 token。',
          ],
        },
      ];

      const REFS = [
        { label: 'Llama 3 训练量 15T', v: 15e12 },
        { label: 'Qwen3 训练量 36T', v: 36e12 },
      ];

      const PAL = ['--indigo', '--madder', '--weld', '--indigo-soft', '--ink-faint'];

      let sortKey: 'year' | 'size' = 'year';
      let showRef = true;
      let sel = 'dclmbaseline';

      const $ = <T extends HTMLElement>(s: string) => root.querySelector<T>(s)!;
      const svgEl = (tag: string, attrs: Record<string, string | number>, text?: string) => {
        const e = document.createElementNS('http://www.w3.org/2000/svg', tag);
        for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, String(v));
        if (text !== undefined) e.textContent = text;
        return e;
      };
      const fmtTok = (t: number) => {
        if (t >= 1e12) return (t / 1e12).toFixed(t >= 1e13 ? 0 : 1) + 'T';
        if (t >= 1e9) return (t / 1e9).toFixed(0) + 'B';
        return t.toExponential(1);
      };
      const cssColor = (name: string) => getComputedStyle(root).getPropertyValue(name).trim() || '#888';

      const LO = Math.log10(5e8); // 轴左端
      const HI = Math.log10(3e14); // 轴右端，留出 240T 的位置

      function draw() {
        const rows = DATA.slice().sort((a, b) => {
          if (sortKey === 'year') return a.year - b.year; // 同年保持 DATA 里的顺序（= 讲义里的讲述顺序）
          return (b.tok ?? -1) - (a.tok ?? -1);
        });

        const RH = 21,
          ML = 150,
          MR = 46,
          MT = 30,
          MB = 26,
          W = 620;
        const H = MT + rows.length * RH + MB;
        const px = (t: number) => ML + ((Math.log10(t) - LO) / (HI - LO)) * (W - ML - MR);

        const svg = svgEl('svg', { viewBox: `0 0 ${W} ${H}` });
        svg.append(svgEl('text', { class: 'title', x: 4, y: 13 }, '横条长度 = token 量（对数刻度）·点任意一行看细节'));

        // 竖网格线 + 刻度
        for (let e = 9; e <= 14; e++) {
          const x = px(Math.pow(10, e));
          svg.append(svgEl('line', { class: 'grid', x1: x, y1: MT - 6, x2: x, y2: H - MB }));
          const lbl = e === 9 ? '1B' : e === 10 ? '10B' : e === 11 ? '100B' : e === 12 ? '1T' : e === 13 ? '10T' : '100T';
          svg.append(svgEl('text', { x, y: H - MB + 12, 'text-anchor': 'middle' }, lbl));
        }
        svg.append(svgEl('line', { class: 'axis', x1: ML, y1: MT - 6, x2: ML, y2: H - MB }));

        if (showRef) {
          REFS.forEach((r, i) => {
            const x = px(r.v);
            svg.append(svgEl('line', { class: 'refline', x1: x, y1: MT - 6, x2: x, y2: H - MB }));
            svg.append(
              svgEl('text', { class: 'gold', x: x + 2, y: MT - 8 + i * 10, 'text-anchor': 'start' }, r.label),
            );
          });
        }

        rows.forEach((d, i) => {
          const y = MT + i * RH;
          const isSel = d.id === sel;
          svg.append(
            svgEl(
              'text',
              { class: 'name' + (isSel ? ' sel' : ''), x: ML - 6, y: y + 12, 'text-anchor': 'end' },
              `${d.year}　${d.name}`,
            ),
          );
          if (d.tok === null) {
            svg.append(svgEl('line', { class: 'nod', x1: ML, y1: y + 9, x2: ML + 24, y2: y + 9 }));
            svg.append(svgEl('text', { x: ML + 28, y: y + 12 }, '课上没给 token 数'));
          } else {
            const w = Math.max(2, px(d.tok) - ML);
            svg.append(svgEl('rect', { class: 'bar' + (isSel ? ' sel' : ''), x: ML, y: y + 3, width: w, height: 12, rx: 2 }));
            svg.append(svgEl('text', { class: 'val', x: ML + w + 4, y: y + 12 }, fmtTok(d.tok)));
          }
          const hit = svgEl('rect', { class: 'hit', x: 0, y, width: W, height: RH });
          hit.addEventListener('click', () => {
            sel = d.id;
            draw();
          });
          svg.append(hit);
        });

        $('[data-plot]').replaceChildren(svg);
        detail(DATA.find((d) => d.id === sel)!);
      }

      function detail(d: DS) {
        const box = $('[data-detail]');
        box.replaceChildren();

        const h = document.createElement('h4');
        h.textContent = d.name;
        const sp = document.createElement('span');
        sp.textContent = `${d.year} · ${d.org}`;
        h.append(sp);
        box.append(h);

        const dl = document.createElement('dl');
        const put = (k: string, v: string) => {
          const dt = document.createElement('dt');
          dt.textContent = k;
          const dd = document.createElement('dd');
          dd.textContent = v;
          dl.append(dt, dd);
        };
        put('规模', d.tok === null ? d.tokNote : `${d.tokNote}${d.size !== '—' ? '，' + d.size : ''}`);
        put('来源', d.kind);
        put('筛选方法', d.method);
        box.append(dl);

        const ul = document.createElement('ul');
        d.notes.forEach((n) => {
          const li = document.createElement('li');
          li.textContent = n;
          ul.append(li);
        });
        box.append(ul);

        if (d.comp) {
          const wrap = document.createElement('div');
          wrap.className = 'comp';
          const cap = document.createElement('dt');
          cap.textContent = `来源构成（${d.compUnit}）`;
          wrap.append(cap);

          const total = d.comp.reduce((s, c) => s + c.v, 0);
          const bar = document.createElement('div');
          bar.className = 'compbar';
          d.comp.forEach((c, i) => {
            const seg = document.createElement('i');
            seg.style.width = (c.v / total) * 100 + '%';
            seg.style.background = cssColor(PAL[i % PAL.length]);
            seg.style.opacity = String(1 - 0.16 * Math.floor(i / PAL.length));
            seg.title = c.label;
            bar.append(seg);
          });
          wrap.append(bar);

          const tb = document.createElement('table');
          d.comp.forEach((c, i) => {
            const tr = document.createElement('tr');
            const t0 = document.createElement('td');
            t0.className = 'sw';
            const chip = document.createElement('i');
            chip.style.background = cssColor(PAL[i % PAL.length]);
            chip.style.opacity = String(1 - 0.16 * Math.floor(i / PAL.length));
            t0.append(chip);
            const t1 = document.createElement('td');
            t1.textContent = c.label;
            const t2 = document.createElement('td');
            t2.className = 'v';
            t2.textContent = c.v.toLocaleString('en-US');
            tr.append(t0, t1, t2);
            // 单位本身就是百分比时，再算一遍占比是多余的
            if (!(d.compUnit || '').includes('%')) {
              const t3 = document.createElement('td');
              t3.className = 'v';
              t3.textContent = ((c.v / total) * 100).toFixed(2) + '%';
              tr.append(t3);
            }
            tb.append(tr);
          });
          wrap.append(tb);
          box.append(wrap);
        }
      }

      root.querySelectorAll<HTMLButtonElement>('[data-sort]').forEach((b) => {
        b.addEventListener('click', () => {
          sortKey = b.dataset.sort as 'year' | 'size';
          root.querySelectorAll('[data-sort]').forEach((x) => x.classList.toggle('on', x === b));
          draw();
        });
      });
      $('[data-ref]').addEventListener('click', () => {
        showRef = !showRef;
        $('[data-ref]').classList.toggle('on', showRef);
        draw();
      });

      draw();
    });
  }

  setupL13Datasets();
  document.addEventListener('astro:page-load', setupL13Datasets);
</script>
