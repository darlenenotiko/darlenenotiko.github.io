---
interface Props {
  src: string;
  caption?: string;
  alt?: string;
  /** 视频用（无人机实拍、轨迹回放等）。传 .mp4/.webm 即可 */
  video?: boolean;
  /** 视频是否自动循环播放（当作 GIF 用），默认 true */
  loop?: boolean;
  /** 超出正文宽度，用于宽图表 */
  wide?: boolean;
}

const { src, caption, alt = caption ?? '', video = false, loop = true, wide = false } = Astro.props;
const isVideo = video || /\.(mp4|webm|mov)$/i.test(src);
---

<figure class:list={['figure', { wide }]}>
  {
    isVideo ? (
      <video
        src={src}
        autoplay={loop}
        loop={loop}
        muted
        playsinline
        controls={!loop}
        preload="metadata"
      />
    ) : (
      <img src={src} alt={alt} loading="lazy" decoding="async" />
    )
  }
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin: 2rem 0;
  }
  .figure.wide {
    /* 挣脱正文测量宽度，最宽到页面容器 */
    width: min(var(--page), 92vw);
    margin-inline: calc(50% - min(var(--page), 92vw) / 2);
  }
  .figure :global(img),
  .figure :global(video) {
    display: block;
    width: 100%;
    border-radius: 3px;
    border: 1px solid var(--rule);
    background: var(--bg-sunken);
  }
  figcaption {
    margin-top: 0.65rem;
    font-size: 0.86rem;
    line-height: 1.6;
    color: var(--ink-muted);
    text-align: center;
    text-wrap: pretty;
  }

  /* 系统开启「减少动效」时，自动播放的循环视频改为可手动控制 */
  @media (prefers-reduced-motion: reduce) {
    .figure :global(video[autoplay]) {
      /* 浏览器不会因此暂停，但至少不再无限吸引注意 */
      animation: none;
    }
  }
</style>
